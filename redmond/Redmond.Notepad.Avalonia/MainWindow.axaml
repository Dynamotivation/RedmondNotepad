<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Redmond.Notepad.Avalonia"
        xmlns:shared="using:Redmond.Avalonia.Controls"
        x:Class="Redmond.Notepad.Avalonia.MainWindow"
        Title="Untitled - Notepad"
        Width="900"
        Height="600"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="#F3F3F3">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="ChromeHoverBrush" Color="#343C4B" />
          <SolidColorBrush x:Key="NotepadTitleBarBrush" Color="#202020" />
          <SolidColorBrush x:Key="NotepadSelectedTabBrush" Color="#1B202B" />
          <SolidColorBrush x:Key="NotepadMenuBarBrush" Color="#1B202B" />
          <SolidColorBrush x:Key="NotepadEditorBrush" Color="#292B32" />
          <SolidColorBrush x:Key="NotepadStatusBrush" Color="#1B2332" />
          <SolidColorBrush x:Key="NotepadDividerBrush" Color="#364052" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="ChromeHoverBrush" Color="#11000000" />
          <SolidColorBrush x:Key="NotepadTitleBarBrush" Color="#F3F3F3" />
          <SolidColorBrush x:Key="NotepadSelectedTabBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="NotepadMenuBarBrush" Color="#F9F9F9" />
          <SolidColorBrush x:Key="NotepadEditorBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="NotepadStatusBrush" Color="#F3F3F3" />
          <SolidColorBrush x:Key="NotepadDividerBrush" Color="#D8D8D8" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <FontFamily x:Key="RedmondFluentIconFont">avares://Redmond.Avalonia.Controls/Assets/RedmondFluentIcons.ttf#Calculator Fluent Icons</FontFamily>
    </ResourceDictionary>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.chrome">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.chrome:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0,0,16,0" />
      <Setter Property="Margin" Value="-8,0,-8,0" />
      <Setter Property="ZIndex" Value="1" />
      <Setter Property="Template">
        <ControlTemplate>
          <ItemsPresenter Name="PART_ItemsPresenter"
                          Margin="{TemplateBinding Padding}"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,-16,0" />
      <Setter Property="CornerRadius" Value="8,8,0,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ClipToBounds="False">
            <Path Classes="inverseCorner"
                  Width="8"
                  Height="8"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  IsVisible="False"
                  Fill="{TemplateBinding Background}"
                  Stretch="Fill"
                  Data="M 8,0 L 8,8 L 0,8 C 4.4,8 8,4.4 8,0 Z" />
            <Path Classes="inverseCorner"
                  Width="8"
                  Height="8"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  IsVisible="False"
                  Fill="{TemplateBinding Background}"
                  Stretch="Fill"
                  Data="M 0,0 L 0,8 L 8,8 C 3.6,8 0,4.4 0,0 Z" />
            <Border Margin="8,0"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
      <Setter Property="ZIndex" Value="1" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected:focus">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected /template/ Path.inverseCorner">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="TextBox.editor">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="TextBox.editor:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.editor /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.editor:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </Window.Styles>

  <Grid>
  <Border x:Name="WindowSurface"
          Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1"
          CornerRadius="8"
          ClipToBounds="True">
  <Grid RowDefinitions="42,38,*,27">
    <Grid x:Name="DocumentTitleBar"
          Background="{DynamicResource NotepadTitleBarBrush}">
      <shared:WindowDragRegion BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                               BorderThickness="0,0,0,1" />
      <Grid x:Name="TitleBarContent"
            ColumnDefinitions="Auto,*"
            Margin="8,5,0,0">
        <Image Width="18"
               Height="18"
               Margin="6,0,10,5"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
          <ListBox x:Name="TabsList"
                   Classes="tabStrip"
                   MaxWidth="610"
                   Height="37"
                   SelectionMode="Single"
                   SelectionChanged="OnTabSelectionChanged"
                   ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:CompileBindings="False">
                <Grid Width="210" Height="37" ColumnDefinitions="*,34">
                  <TextBlock Margin="12,0,4,0"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding Title}" />
                  <Button Grid.Column="1"
                          Classes="chrome"
                          Width="28"
                          Height="28"
                          Padding="0"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          CommandParameter="{Binding}"
                          Click="OnCloseTabClick"
                          AutomationProperties.Name="Close tab">
                    <Path Width="10"
                          Height="10"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.4"
                          StrokeLineCap="Round"
                          Data="M 1,1 L 9,9 M 9,1 L 1,9" />
                  </Button>
                  <Border Grid.ColumnSpan="2"
                          Width="1"
                          Height="22.2"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"
                          IsVisible="{Binding ShowLeadingSeparator}"
                          Opacity="0.6"
                          Background="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Grid Width="37" Height="37">
            <Button Classes="chrome"
                    Width="28"
                    Height="28"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnNewTabClick"
                    AutomationProperties.Name="New tab">
              <Path Width="12"
                    Height="12"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.4"
                    StrokeLineCap="Round"
                    Data="M 6,0 L 6,12 M 0,6 L 12,6" />
            </Button>
          </Grid>
        </StackPanel>
      </Grid>
    </Grid>

    <Grid x:Name="SettingsTitleBar" IsVisible="False">
      <shared:WindowDragRegion BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                               BorderThickness="0,0,0,1" />
      <Grid x:Name="SettingsTitleBarContent"
            Height="42"
            ColumnDefinitions="44,Auto,*"
            Margin="8,0,0,0">
        <Button Classes="chrome"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnBackFromSettingsClick"
                AutomationProperties.Name="Back">
          <Path Width="18" Height="18" Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeThickness="1.25"
                Data="M 12.5,5.5 L 6,12 L 12.5,18.5 M 6,12 L 20,12" />
        </Button>
        <Image Grid.Column="1"
               Width="20"
               Height="20"
               Margin="0,0,10,0"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        <TextBlock Grid.Column="2"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Text="Notepad" />
      </Grid>
    </Grid>

    <Grid x:Name="DocumentPage"
          Grid.Row="1"
          Grid.RowSpan="3"
          RowDefinitions="38,*,27">
    <Border Grid.Row="0" Background="{DynamicResource NotepadMenuBarBrush}">
    <Grid x:Name="DocumentMenuBar"
          ColumnDefinitions="*,Auto"
          Margin="7,3">
      <StackPanel Orientation="Horizontal" Spacing="1">
        <Button Classes="chrome" Content="File" />
        <Button Classes="chrome" Content="Edit" />
        <Button Classes="chrome" Content="View" />
      </StackPanel>
      <Button Grid.Column="1"
              Classes="chrome"
              Width="36"
              Height="32"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Click="OnSettingsClick"
              ToolTip.Tip="Settings"
              AutomationProperties.Name="Settings">
        <TextBlock FontFamily="{StaticResource RedmondFluentIconFont}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="17"
                   Text="&#xE713;" />
      </Button>
    </Grid>
    </Border>

    <Border Grid.Row="1" Background="{DynamicResource NotepadEditorBrush}">
    <TextBox x:Name="Editor"
             Classes="editor"
             Padding="14,10"
             AcceptsReturn="True"
             AcceptsTab="True"
             TextWrapping="Wrap"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch"
             FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
             FontSize="14"
             PlaceholderText="Type something…"
             AutomationProperties.Name="Text editor" />
    </Border>

    <Border Grid.Row="2"
            Background="{DynamicResource NotepadStatusBrush}"
            BorderBrush="{DynamicResource NotepadDividerBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="12,0"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center">
        <TextBlock x:Name="DocumentSummary"
                   FontSize="12"
                   Opacity="0.72"
                   Text="1 line · 0 characters" />
        <TextBlock x:Name="CursorStatus"
                   Grid.Column="1"
                   Margin="14,0"
                   FontSize="12"
                   Text="Ln 1, Col 1" />
        <TextBlock Grid.Column="2" Margin="14,0" FontSize="12" Text="100%" />
        <TextBlock x:Name="LineEndingStatus"
                   Grid.Column="3"
                   Margin="14,0"
                   FontSize="12"
                   Text="Windows (CRLF)" />
        <TextBlock Grid.Column="4" Margin="14,0,2,0" FontSize="12" Text="UTF-8" />
      </Grid>
    </Border>
    </Grid>

    <local:SettingsPage x:Name="SettingsPage"
                        Grid.Row="1"
                        Grid.RowSpan="3"
                        IsVisible="False" />

    <shared:WindowCaptionButtons x:Name="CaptionButtons"
                                 Grid.Row="0"
                                 ZIndex="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top" />
  </Grid>
  </Border>
  <shared:WindowResizeHandles x:Name="ResizeHandles" />
  </Grid>
</Window>
