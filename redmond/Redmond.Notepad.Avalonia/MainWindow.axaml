<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Redmond.Notepad.Avalonia"
        xmlns:shared="using:Redmond.Avalonia.Controls"
        xmlns:avaloniaEdit="using:AvaloniaEdit"
        x:Class="Redmond.Notepad.Avalonia.MainWindow"
        Title="Untitled - Notepad"
        Width="900"
        Height="600"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Icon="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="#F3F3F3">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="ChromeHoverBrush" Color="#343C4B" />
          <SolidColorBrush x:Key="NotepadTitleBarBrush" Color="#202020" />
          <SolidColorBrush x:Key="NotepadSelectedTabBrush" Color="#1B202B" />
          <SolidColorBrush x:Key="NotepadMenuBarBrush" Color="#1B202B" />
          <SolidColorBrush x:Key="NotepadEditorBrush" Color="#292B32" />
          <SolidColorBrush x:Key="NotepadStatusBrush" Color="#1B2332" />
          <SolidColorBrush x:Key="NotepadDividerBrush" Color="#364052" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="ChromeHoverBrush" Color="#11000000" />
          <SolidColorBrush x:Key="NotepadTitleBarBrush" Color="#F3F3F3" />
          <SolidColorBrush x:Key="NotepadSelectedTabBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="NotepadMenuBarBrush" Color="#F9F9F9" />
          <SolidColorBrush x:Key="NotepadEditorBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="NotepadStatusBrush" Color="#F3F3F3" />
          <SolidColorBrush x:Key="NotepadDividerBrush" Color="#D8D8D8" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <FontFamily x:Key="RedmondFluentIconFont">avares://Redmond.Avalonia.Controls/Assets/RedmondFluentIcons.ttf#Calculator Fluent Icons</FontFamily>
    </ResourceDictionary>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.chrome">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.chrome:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="RepeatButton.chrome">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="RepeatButton.chrome:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0,0,16,0" />
      <Setter Property="Margin" Value="0,0,-8,0" />
      <Setter Property="ZIndex" Value="1" />
      <Setter Property="Template">
        <ControlTemplate>
          <ItemsPresenter Name="PART_ItemsPresenter"
                          Margin="{TemplateBinding Padding}"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,-16,0" />
      <Setter Property="CornerRadius" Value="8,8,0,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ClipToBounds="False">
            <Path Classes="inverseCorner"
                  Width="8"
                  Height="8"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  IsVisible="False"
                  Fill="{TemplateBinding Background}"
                  Stretch="Fill"
                  Data="M 8,0 L 8,8 L 0,8 C 4.4,8 8,4.4 8,0 Z" />
            <Path Classes="inverseCorner"
                  Width="8"
                  Height="8"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  IsVisible="False"
                  Fill="{TemplateBinding Background}"
                  Stretch="Fill"
                  Data="M 0,0 L 0,8 L 8,8 C 3.6,8 0,4.4 0,0 Z" />
            <Border Margin="8,0"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
      <Setter Property="ZIndex" Value="1" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected:focus">
      <Setter Property="Background" Value="{DynamicResource NotepadSelectedTabBrush}" />
    </Style>
    <Style Selector="ListBox.tabStrip ListBoxItem:selected /template/ Path.inverseCorner">
      <Setter Property="IsVisible" Value="True" />
    </Style>
  </Window.Styles>

  <Grid>
  <Border x:Name="WindowSurface"
          Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1"
          CornerRadius="8"
          ClipToBounds="True">
  <Grid RowDefinitions="Auto,38,*,27">
    <Grid x:Name="DocumentTitleBar"
          Height="48"
          Background="{DynamicResource NotepadTitleBarBrush}">
      <shared:WindowDragRegion />
      <Grid x:Name="TitleBarContent"
            Height="37"
            VerticalAlignment="Bottom"
            ColumnDefinitions="Auto,*"
            Margin="8,0,0,0">
        <Grid Width="37" Height="37">
          <Image Width="22"
                 Height="22"
                 Stretch="Uniform"
                 IsHitTestVisible="False"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        </Grid>
        <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto">
          <RepeatButton x:Name="TabScrollLeftButton"
                        Classes="chrome"
                        Width="28"
                        Height="28"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsVisible="False"
                        Delay="280"
                        Interval="16"
                        Click="OnTabScrollLeftClick"
                        AutomationProperties.Name="Scroll tabs left">
            <Path Width="8" Height="12" Stretch="Fill"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                  StrokeThickness="1.4" StrokeLineCap="Round"
                  Data="M 7,1 L 2,6 L 7,11" />
          </RepeatButton>

          <ScrollViewer x:Name="TabScrollViewer"
                        Grid.Column="1"
                        Height="37"
                        HorizontalAlignment="Left"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        IsScrollChainingEnabled="False"
                        ScrollChanged="OnTabScrollChanged">
            <StackPanel Orientation="Horizontal">
              <ListBox x:Name="TabsList"
                       Classes="tabStrip"
                       Height="37"
                       HorizontalAlignment="Left"
                       SelectionMode="Single"
                       SelectionChanged="OnTabSelectionChanged">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate x:CompileBindings="False">
                    <Grid Width="210" Height="37" ColumnDefinitions="*,34">
                      <TextBlock Margin="12,0,4,0"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 Text="{Binding Title}" />
                      <Button Grid.Column="1"
                              Classes="chrome"
                              Width="28"
                              Height="28"
                              Padding="0"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              CommandParameter="{Binding}"
                              Click="OnCloseTabClick"
                              AutomationProperties.Name="Close tab">
                        <Grid>
                          <Path Width="10"
                                Height="10"
                                IsVisible="{Binding ShowCloseGlyph}"
                                Stretch="Uniform"
                                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                StrokeThickness="1.4"
                                StrokeLineCap="Round"
                                Data="M 1,1 L 9,9 M 9,1 L 1,9" />
                          <Ellipse Width="5"
                                   Height="5"
                                   IsVisible="{Binding ShowModifiedGlyph}"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Grid>
                      </Button>
                      <Border Grid.ColumnSpan="2"
                              Width="1"
                              Height="22.2"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"
                              IsVisible="{Binding ShowLeadingSeparator}"
                              Opacity="0.6"
                              Background="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                      <Border Grid.ColumnSpan="2"
                              Width="1"
                              Height="22.2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"
                              IsVisible="{Binding ShowTrailingSeparator}"
                              Opacity="0.6"
                              Background="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Grid Width="37" Height="37">
                <Button Classes="chrome"
                        Width="28"
                        Height="28"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnNewTabClick"
                        AutomationProperties.Name="New tab">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        StrokeThickness="1.4"
                        StrokeLineCap="Round"
                        Data="M 6,0 L 6,12 M 0,6 L 12,6" />
                </Button>
              </Grid>
            </StackPanel>
          </ScrollViewer>

          <RepeatButton x:Name="TabScrollRightButton"
                        Grid.Column="2"
                        Classes="chrome"
                        Width="28"
                        Height="28"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsVisible="False"
                        Delay="280"
                        Interval="16"
                        Click="OnTabScrollRightClick"
                        AutomationProperties.Name="Scroll tabs right">
            <Path Width="8" Height="12" Stretch="Fill"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                  StrokeThickness="1.4" StrokeLineCap="Round"
                  Data="M 1,1 L 6,6 L 1,11" />
          </RepeatButton>
        </Grid>
      </Grid>
    </Grid>

    <Grid x:Name="SettingsTitleBar" Height="42" IsVisible="False">
      <shared:WindowDragRegion BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                               BorderThickness="0,0,0,1" />
      <Grid x:Name="SettingsTitleBarContent"
            Height="42"
            ColumnDefinitions="44,Auto,*"
            Margin="8,0,0,0">
        <Button Classes="chrome"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnBackFromSettingsClick"
                AutomationProperties.Name="Back">
          <Path Width="18" Height="18" Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeThickness="1.25"
                Data="M 12.5,5.5 L 6,12 L 12.5,18.5 M 6,12 L 20,12" />
        </Button>
        <Image Grid.Column="1"
               Width="20"
               Height="20"
               Margin="0,0,10,0"
               Stretch="Uniform"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        <TextBlock Grid.Column="2"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Text="Notepad" />
      </Grid>
    </Grid>

    <Grid x:Name="DocumentPage"
          Grid.Row="1"
          Grid.RowSpan="3"
          RowDefinitions="38,*,27">
    <Border Grid.Row="0" Background="{DynamicResource NotepadMenuBarBrush}">
    <Grid x:Name="DocumentMenuBar"
          ColumnDefinitions="*,Auto"
          Margin="7,3">
      <StackPanel Orientation="Horizontal" Spacing="1">
        <Button Classes="chrome" Content="File">
          <Button.Flyout>
            <MenuFlyout Placement="BottomEdgeAlignedLeft">
              <MenuItem x:Name="NewTabMenuItem" Header="New tab" Click="OnNewTabClick" />
              <MenuItem x:Name="NewWindowMenuItem" Header="New window" Click="OnNewWindowClick" />
              <MenuItem x:Name="OpenMenuItem" Header="Open" Click="OnOpenFilesClick" />
              <MenuItem Header="-" />
              <MenuItem x:Name="SaveMenuItem" Header="Save" Click="OnSaveClick" />
              <MenuItem x:Name="SaveAsMenuItem" Header="Save as" Click="OnSaveAsClick" />
              <MenuItem x:Name="SaveAllMenuItem" Header="Save all" Click="OnSaveAllClick" />
              <MenuItem Header="-" />
              <MenuItem Header="Page setup" Click="OnPageSetupClick" />
              <MenuItem x:Name="PrintMenuItem" Header="Print" Click="OnPrintClick" />
              <MenuItem Header="-" />
              <MenuItem x:Name="CloseTabMenuItem" Header="Close tab" Click="OnCloseSelectedTabClick" />
              <MenuItem x:Name="CloseWindowMenuItem" Header="Close window" Click="OnCloseWindowClick" />
              <MenuItem Header="Exit" Click="OnExitClick" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
        <Button Classes="chrome" Content="Edit" />
        <Button Classes="chrome" Content="View" />
      </StackPanel>
      <Button Grid.Column="1"
              Classes="chrome"
              Width="36"
              Height="32"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Click="OnSettingsClick"
              ToolTip.Tip="Settings"
              AutomationProperties.Name="Settings">
        <TextBlock FontFamily="{StaticResource RedmondFluentIconFont}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="17"
                   Text="&#xE713;" />
      </Button>
    </Grid>
    </Border>

    <Border Grid.Row="1"
            Padding="14,10"
            Background="{DynamicResource NotepadEditorBrush}">
    <avaloniaEdit:TextEditor x:Name="Editor"
                             Background="Transparent"
                             WordWrap="True"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                             FontSize="14"
                             Watermark="Type something…"
                             AutomationProperties.Name="Text editor" />
    </Border>

    <Border Grid.Row="2"
            Background="{DynamicResource NotepadStatusBrush}"
            BorderBrush="{DynamicResource NotepadDividerBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="12,0"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center">
        <TextBlock x:Name="DocumentSummary"
                   FontSize="12"
                   Opacity="0.72"
                   Text="1 line · 0 characters" />
        <TextBlock x:Name="CursorStatus"
                   Grid.Column="1"
                   Margin="14,0"
                   FontSize="12"
                   Text="Ln 1, Col 1" />
        <TextBlock Grid.Column="2" Margin="14,0" FontSize="12" Text="100%" />
        <TextBlock x:Name="LineEndingStatus"
                   Grid.Column="3"
                   Margin="14,0"
                   FontSize="12"
                   Text="Windows (CRLF)" />
        <TextBlock x:Name="EncodingStatus"
                   Grid.Column="4"
                   Margin="14,0,2,0"
                   FontSize="12"
                   Text="UTF-8" />
      </Grid>
    </Border>
    </Grid>

    <local:SettingsPage x:Name="SettingsPage"
                        Grid.Row="1"
                        Grid.RowSpan="3"
                        IsVisible="False" />

    <shared:WindowCaptionButtons x:Name="CaptionButtons"
                                 Grid.Row="0"
                                 ZIndex="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top" />
  </Grid>
  </Border>
  <shared:WindowResizeHandles x:Name="ResizeHandles" />

  <Border x:Name="UnsavedChangesOverlay"
          ZIndex="20"
          IsVisible="False"
          Background="#66000000">
    <Border Width="440"
            Padding="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource NotepadEditorBrush}"
            BorderBrush="{DynamicResource NotepadDividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
      <StackPanel Spacing="14">
        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Text="Save changes?" />
        <TextBlock x:Name="UnsavedChangesMessage"
                   TextWrapping="Wrap" />
        <StackPanel Margin="0,8,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Content="Cancel"
                  Click="OnCancelUnsavedChangesClick" />
          <Button Content="Don't save"
                  Click="OnDiscardUnsavedChangesClick" />
          <Button x:Name="SaveUnsavedChangesButton"
                  Content="Save"
                  Click="OnSaveUnsavedChangesClick" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>

  <Border x:Name="ExternalChangesOverlay"
          ZIndex="21"
          IsVisible="False"
          Background="#66000000">
    <Border Width="520"
            Padding="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource NotepadEditorBrush}"
            BorderBrush="{DynamicResource NotepadDividerBrush}"
            BorderThickness="1"
            CornerRadius="8">
      <StackPanel Spacing="14">
        <TextBlock x:Name="ExternalChangesTitle"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="File changed outside Redmond Notepad" />
        <TextBlock x:Name="ExternalChangesMessage"
                   TextWrapping="Wrap" />
        <TextBlock x:Name="ExternalChangesWarning"
                   Opacity="0.72"
                   Text="Reload discards your edits. Overwrite permanently replaces the other version."
                   TextWrapping="Wrap" />
        <StackPanel Margin="0,8,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Content="Cancel"
                  Click="OnCancelExternalChangesClick" />
          <Button x:Name="ReloadExternalChangesButton"
                  Content="Reload"
                  Click="OnReloadExternalChangesClick" />
          <Button x:Name="OverwriteExternalChangesButton"
                  Content="Overwrite"
                  Click="OnOverwriteExternalChangesClick" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>
  </Grid>
</Window>
