<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Redmond.Notepad.Avalonia"
        xmlns:shared="using:Redmond.Avalonia.Controls"
        x:Class="Redmond.Notepad.Avalonia.MainWindow"
        Title="Untitled - Notepad"
        Width="900"
        Height="600"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="#F3F3F3">

  <Window.Resources>
    <SolidColorBrush x:Key="ChromeHoverBrush" Color="#11000000" />
    <FontFamily x:Key="RedmondFluentIconFont">avares://Redmond.Avalonia.Controls/Assets/RedmondFluentIcons.ttf#Calculator Fluent Icons</FontFamily>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.chrome">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.chrome:pointerover">
      <Setter Property="Background" Value="{StaticResource ChromeHoverBrush}" />
    </Style>
  </Window.Styles>

  <Grid>
  <Border x:Name="WindowSurface"
          Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
          BorderThickness="1"
          CornerRadius="8"
          ClipToBounds="True">
  <Grid RowDefinitions="42,38,*,27">
    <Grid x:Name="DocumentTitleBar">
      <shared:WindowDragRegion BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                               BorderThickness="0,0,0,1" />
      <Grid x:Name="TitleBarContent"
            ColumnDefinitions="Auto,220,Auto,*"
            Margin="8,5,0,0">
        <Image Width="24"
               Height="24"
               Margin="4,0,8,5"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        <Border Grid.Column="1"
                Margin="0,0,4,0"
                Padding="12,0"
                CornerRadius="7,7,0,0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock VerticalAlignment="Center" Text="Untitled" />
            <Button Grid.Column="1"
                    Classes="chrome"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Content="×"
                    AutomationProperties.Name="Close tab" />
          </Grid>
        </Border>
        <Button Grid.Column="2"
                Classes="chrome"
                Width="32"
                Height="32"
                Padding="0"
                FontSize="20"
                Content="+"
                AutomationProperties.Name="New tab" />
      </Grid>
    </Grid>

    <Grid x:Name="SettingsTitleBar" IsVisible="False">
      <shared:WindowDragRegion BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                               BorderThickness="0,0,0,1" />
      <Grid x:Name="SettingsTitleBarContent"
            Height="42"
            ColumnDefinitions="44,Auto,*"
            Margin="8,0,0,0">
        <Button Classes="chrome"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnBackFromSettingsClick"
                AutomationProperties.Name="Back">
          <Path Width="18" Height="18" Stretch="Uniform"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeThickness="1.25"
                Data="M 12.5,5.5 L 6,12 L 12.5,18.5 M 6,12 L 20,12" />
        </Button>
        <Image Grid.Column="1"
               Width="20"
               Height="20"
               Margin="0,0,10,0"
               IsHitTestVisible="False"
               VerticalAlignment="Center"
               Source="avares://Redmond%20Notepad/Assets/RedmondNotepadIcon.png" />
        <TextBlock Grid.Column="2"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Text="Notepad" />
      </Grid>
    </Grid>

    <Grid x:Name="DocumentPage"
          Grid.Row="1"
          Grid.RowSpan="3"
          RowDefinitions="38,*,27">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="7,3">
      <StackPanel Orientation="Horizontal" Spacing="1">
        <Button Classes="chrome" Content="File" />
        <Button Classes="chrome" Content="Edit" />
        <Button Classes="chrome" Content="View" />
      </StackPanel>
      <Button Grid.Column="1"
              Classes="chrome"
              Width="36"
              Height="32"
              Padding="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Click="OnSettingsClick"
              ToolTip.Tip="Settings"
              AutomationProperties.Name="Settings">
        <TextBlock FontFamily="{StaticResource RedmondFluentIconFont}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="17"
                   Text="&#xE713;" />
      </Button>
    </Grid>

    <TextBox x:Name="Editor"
             Grid.Row="1"
             Padding="14,10"
             AcceptsReturn="True"
             AcceptsTab="True"
             TextWrapping="Wrap"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch"
             Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
             BorderThickness="0"
             FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
             FontSize="14"
             PlaceholderText="Type something…"
             AutomationProperties.Name="Text editor" />

    <Border Grid.Row="2"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0">
      <Grid Margin="12,0"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center">
        <TextBlock x:Name="DocumentSummary"
                   FontSize="12"
                   Opacity="0.72"
                   Text="1 line · 0 characters" />
        <TextBlock x:Name="CursorStatus"
                   Grid.Column="1"
                   Margin="14,0"
                   FontSize="12"
                   Text="Ln 1, Col 1" />
        <TextBlock Grid.Column="2" Margin="14,0" FontSize="12" Text="100%" />
        <TextBlock x:Name="LineEndingStatus"
                   Grid.Column="3"
                   Margin="14,0"
                   FontSize="12"
                   Text="Windows (CRLF)" />
        <TextBlock Grid.Column="4" Margin="14,0,2,0" FontSize="12" Text="UTF-8" />
      </Grid>
    </Border>
    </Grid>

    <local:SettingsPage x:Name="SettingsPage"
                        Grid.Row="1"
                        Grid.RowSpan="3"
                        IsVisible="False" />

    <shared:WindowCaptionButtons x:Name="CaptionButtons"
                                 Grid.Row="0"
                                 ZIndex="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top" />
  </Grid>
  </Border>
  <shared:WindowResizeHandles x:Name="ResizeHandles" />
  </Grid>
</Window>
